# Content delivery scheduler
CONTENT_DELIVERY_FREQUENCY=daily
CONTENT_DELIVERY_TIME=09:00
CONTENT_DELIVERY_TIMEZONE=America/Sao_Paulo
CONTENT_DELIVERY_CHANNELS=email
CONTENT_DELIVERY_LESSON_STATUSES=review,approved
CONTENT_DELIVERY_BATCH_LIMIT=50
GENERATED_LESSON_STATUS=approved
