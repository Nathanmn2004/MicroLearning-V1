# Optional direct SQL connections for migrations or admin scripts.
DATABASE_URL=
DIRECT_URL=

# Redis / Arq
REDIS_URL=redis://redis:6379/0

# AI
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Cakto
CAKTO_CHECKOUT_URL=
